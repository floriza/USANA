# Copy this file to .env.staging on the Hostinger VPS (never commit the real file)
# Location: /opt/usana-store/.env.staging

NODE_ENV=production
PORT=3000

# ── Database (Supabase Staging Project) ──────────────────────────────────────
# Create a SEPARATE Supabase project for staging at supabase.com
# Go to: Settings → Database → Connection string → Session pooler
DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET="generate-a-new-secret-do-not-reuse-production"
NEXTAUTH_URL="https://staging.yourdomain.com"
NEXT_PUBLIC_APP_URL="https://staging.yourdomain.com"
NEXT_PUBLIC_APP_NAME="USANA Store Staging"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Same Google Cloud project — just add staging redirect URI:
# https://staging.yourdomain.com/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── PayMongo (USE TEST KEYS ON STAGING — never live keys) ────────────────────
PAYMONGO_SECRET_KEY="sk_test_XXXX"
PAYMONGO_PUBLIC_KEY="pk_test_XXXX"
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY="pk_test_XXXX"
# Webhook: register https://staging.yourdomain.com/api/webhooks/paymongo in PayMongo dashboard
PAYMONGO_WEBHOOK_SECRET="whsec_XXXX"

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_XXXX"
RESEND_FROM_NAME="USANA Store Staging"
RESEND_FROM_EMAIL="staging@yourdomain.com"

# ── Cloudflare R2 (file uploads) ─────────────────────────────────────────────
# Can reuse production credentials with a separate staging bucket
CLOUDFLARE_R2_ACCOUNT_ID="XXXX"
CLOUDFLARE_R2_ACCESS_KEY_ID="XXXX"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="XXXX"
CLOUDFLARE_R2_BUCKET_NAME="usana-store-staging"
CLOUDFLARE_R2_PUBLIC_URL="https://pub-XXXX.r2.dev"
