<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- ============================================================
         Reverse proxy: forward all requests to Next.js on port 3000
         Requires: IIS URL Rewrite + Application Request Routing (ARR)
    ============================================================ -->
    <rewrite>
      <rules>
        <!-- Static files served directly by IIS for performance -->
        <rule name="Static Assets" stopProcessing="true">
          <match url="^_next/static/(.*)" />
          <action type="Rewrite" url="/_next/static/{R:1}" />
        </rule>

        <!-- Proxy everything else to Next.js -->
        <rule name="Proxy to Next.js" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{CACHE_URL}" pattern="^(https?)://" />
          </conditions>
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>

        <!-- Fallback rule without CACHE_URL condition -->
        <rule name="Proxy to Next.js Fallback" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- ============================================================
         ARR proxy settings
    ============================================================ -->
    <proxy enabled="true" preserveHostHeader="true" reverseRewriteHostInResponseHeaders="false" />

    <!-- ============================================================
         Security headers (supplement Next.js headers)
    ============================================================ -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <remove name="Server" />
      </customHeaders>
    </httpProtocol>

    <!-- ============================================================
         Error pages
    ============================================================ -->
    <httpErrors errorMode="DetailedLocalOnly" />

    <!-- ============================================================
         Compression
    ============================================================ -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

  </system.webServer>
</configuration>
